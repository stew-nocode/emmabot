    {
      "parameters": {
        "jsCode": "const SEUIL = 5; // Modifier ici pour ajuster le seuil d'alerte\nconst rows = $input.all().map(i => i.json);\n\nfunction isTraite(r) {\n  const t = r.traite;\n  if (t === undefined || t === null) return false;\n  const s = String(t).trim().toLowerCase();\n  if (s === '') return false;\n  return ['oui','yes','true','1','traite','ok'].includes(s);\n}\n\nconst nonTraites = rows.filter(r => !isTraite(r));\nconst nbTotal = rows.length;\nconst nbNonTraites = nonTraites.length;\n\n// Top 5 questions non traitées les plus récentes pour le mail\nconst apercu = nonTraites\n  .filter(r => r.questions_posees && r.questions_posees.trim().length > 0)\n  .sort((a, b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0))\n  .slice(0, 5)\n  .map(r => r.questions_posees.trim());\n\nreturn [{\n  json: {\n    nbNonTraites,\n    nbTotal,\n    apercu,\n    seuil: SEUIL,\n    seuilDepasse: nbNonTraites >= SEUIL,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0],
      "id": "code-backlog-calc-0001-000000000001",
      "name": "Calcul backlog"
    },
